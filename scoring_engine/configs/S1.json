  "omissions": [
    {
      "id": 1,
      "topic": "Scheduling Rules",
      "weight": "CRITICAL",
      "points": 15,
      "keywords": [
        "long",
        "duration",
        "overlap",
        "assign",
        "time window",
        "book",
        "hour",
        "minute",
        "slot",
        "how long",
        "window"
      ],
      "answer": "Jobs are 30min, 1hr, or 2hr based on service type. No overlapping appointments per technician. Office manager assigns manually. Customers can request preferred time slots but scheduling is done by the office.",
      "strong_signals": [
        "duration",
        "overlap",
        "time window",
        "how long"
      ],
      "ct_category": "Functional",
      "trap_type": "Original"
    },
    {
      "id": 2,
      "topic": "Customer Data Format",
      "weight": "HIGH",
      "points": 10,
      "keywords": [
        "CSV",
        "columns",
        "format",
        "fields",
        "encoding",
        "sample",
        "full",
        "records",
        "what's in",
        "structure"
      ],
      "answer": "Columns: first_name, last_name, email, phone, address, city, state, zip, service_type (mowing, fertilization, aeration, full_package), frequency (weekly, biweekly, monthly), notes. UTF-8 encoding. This is the full active customer list \u2014 47 customers.",
      "strong_signals": [
        "CSV",
        "columns",
        "encoding",
        "what's in"
      ],
      "ct_category": "Functional",
      "trap_type": "Original"
    },
    {
      "id": 3,
      "topic": "Authentication & User Accounts",
      "weight": "HIGH",
      "points": 10,
      "keywords": [
        "account",
        "create",
        "register",
        "sign up",
        "password",
        "reset",
        "login",
        "credential"
      ],
      "answer": "Office manager creates all accounts. No self-registration. Password reset sends an email with a temporary link valid for 24 hours.",
      "strong_signals": [
        "register",
        "sign up",
        "password reset",
        "self-registration"
      ],
      "ct_category": "Security",
      "trap_type": "Original"
    },
    {
      "id": 4,
      "topic": "Job Completion Details",
      "weight": "HIGH",
      "points": 10,
      "keywords": [
        "complete",
        "completion",
        "status",
        "notes",
        "photo",
        "notify",
        "notification",
        "start",
        "in progress",
        "what does",
        "involve",
        "details"
      ],
      "answer": "Technician taps 'Complete' which changes status and records timestamp. Optional notes field (max 500 chars). Optional photo upload (up to 3). Customer gets a confirmation email. Jobs cannot be completed unless status is 'In Progress'.",
      "strong_signals": [
        "photo",
        "notification",
        "in progress",
        "what does",
        "involve"
      ],
      "ct_category": "Functional",
      "trap_type": "Original"
    },
    {
      "id": 5,
      "topic": "Print Daily Schedule Content",
      "weight": "MODERATE",
      "points": 5,
      "keywords": [
        "print",
        "daily",
        "what",
        "information",
        "address",
        "direction",
        "route",
        "contain",
        "include",
        "on it",
        "show"
      ],
      "answer": "Office manager prints one schedule per technician. Shows: time, customer name, address, service type, duration, and any notes. No driving directions needed \u2014 techs know the area.",
      "ct_category": "Functional",
      "trap_type": "Original"
    },
    {
      "id": 6,
      "topic": "Cancellation / No-Show / Reschedule / Weather",
      "weight": "MODERATE",
      "points": 5,
      "keywords": [
        "cancel",
        "no-show",
        "reschedule",
        "weather",
        "rain",
        "policy",
        "missed",
        "absent",
        "what if",
        "happen",
        "edge",
        "delay"
      ],
      "answer": "Customer can cancel or reschedule by calling the office. No automated cancellation. If weather prevents work, office manager reschedules all affected jobs and notifies customers. No cancellation fees.",
      "ct_category": "Functional",
      "trap_type": "Original"
    },
    {
      "id": 7,
      "topic": "Customer Data Ownership & Portability (Operational Trap)",
      "weight": "HIGH",
      "points": 10,
      "keywords": [
        "own",
        "sell",
        "portab",
        "export",
        "transfer",
        "customer list",
        "if sold",
        "acquire",
        "buyer",
        "data owner",
        "belongs to"
      ],
      "answer": "Maria (the owner) owns all customer data. If the business is sold, the customer list transfers with the sale. The system should support exporting all customer data to CSV at any time. The app itself is a business asset \u2014 if sold, the buyer gets the system and all data.",
